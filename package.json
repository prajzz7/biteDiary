{
  "name": "bitediary",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "start:backend": "npm run start --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "start:frontend": "npm run start --workspace frontend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:backend": "npm run typecheck --workspace backend",
    "typecheck:frontend": "npm run typecheck --workspace frontend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:studio": "npm run prisma:studio --workspace backend"
  }
}
