// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurants      Restaurant[]
  restaurantVisits RestaurantVisit[]
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  cuisine   String?
  city      String?
  state     String?
  country   String?
  address   String?
  notes     String?  
  bannerImageUrl String?
  bannerImagePublicId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  visits    RestaurantVisit[]

  @@index([userId])
}

model RestaurantVisit {
  id              String    @id @default(cuid())
  visitNotes      String?
  rating          Float?
  visitedAt       DateTime?
  totalAmountPaid Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dishes Dish[]

  @@index([restaurantId])
  @@index([userId])
  @@index([visitedAt])
  @@index([userId, visitedAt])
  @@index([restaurantId, visitedAt])
}

model Dish {
  id            String  @id @default(cuid())
  name          String
  rating        Float?
  price         Float?
  notes         String?
  wouldEatAgain Boolean @default(false)


  restaurantVisitId String
  restaurantVisit   RestaurantVisit @relation(fields: [restaurantVisitId], references: [id], onDelete: Cascade)

  dishImages DishImages[]

  @@index([restaurantVisitId])
}

model DishImages {
  id String @id @default(cuid())
  dishImageUrl String?
  dishImagePublicUrl String?

  dishId String
  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

}